# === Job Search Assistant - Environment Variables ===

# SerpAPI (Google Jobs) - https://serpapi.com (free: 100 searches/mo)
SERPAPI_KEY=your_serpapi_key_here

# Adzuna - https://developer.adzuna.com (free: 250 req/mo)
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Apollo.io - https://www.apollo.io (free: 50 credits/mo)
APOLLO_API_KEY=your_apollo_api_key_here

# Anthropic Claude API (optional, if you have credits)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API (free) - https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets - Sheet ID from your Google Sheet URL
# https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail - will use Claude MCP connection (no key needed here)
# Make sure Gmail is connected in your Claude.ai settings

# Your Info
USER_EMAIL=sathvik1240@gmail.com
USER_NAME=Sathvik Boorgu
USER_PHONE=+91 75692 89556
